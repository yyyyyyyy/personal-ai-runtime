# Personal AI Runtime v0.3.0
# https://github.com/yyyyyyyy/personal-ai-runtime
# LLM Configuration (required)
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60

# Optional LLM Providers (used for fallback when primary fails)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Memory extraction: ollama (local) or cloud (uses LLM_API_KEY when Ollama unavailable)
MEMORY_EXTRACTOR=ollama

# Sensitive operations routing via local Ollama
# Code default is true; set to false to route sensitive classification to the cloud LLM.
SENSITIVE_OPS_LOCAL=true

# Data Storage — leave blank to use repo-root defaults (backend/data).
# Paths resolve from repo root, NOT process cwd, so they work when uvicorn runs from backend/.
# DATA_DIR=
# SQLITE_PATH=
# VECTOR_DIR=

# Conversation / tool loop
MAX_TOOL_ITERATIONS=10
MAX_RECENT_MESSAGES=50
MAX_TOOL_LOOP_PROMPT_TOKENS=100000
# Per-tool invocation timeout (seconds); applies to MCP/builtin tool handlers
TOOL_TIMEOUT_SECONDS=30
# Total wall-clock budget for one chat turn's tool loop (seconds)
TOTAL_TOOL_LOOP_TIMEOUT=300

# LLM generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# submit_command per-call-site timeouts (seconds).
# submit_command emits an event and awaits the matching *Completed event;
# these control how long the await blocks before returning {"error":"timeout"}.
# - SUBMIT_COMMAND_TIMEOUT_APPROVAL: human-in-the-loop approval resolution (default 60s)
# - SUBMIT_COMMAND_TIMEOUT_BACKGROUND_TASK: autonomous background plan execution (default 300s)
# - SUBMIT_COMMAND_TIMEOUT_INBOX: scheduled inbox poll + digest (default 300s)
SUBMIT_COMMAND_TIMEOUT_APPROVAL=60
SUBMIT_COMMAND_TIMEOUT_BACKGROUND_TASK=300
SUBMIT_COMMAND_TIMEOUT_INBOX=300

# Filesystem (agent coding) — comma-separated paths; leave blank for defaults
# Default allowed: project root + home directory
# FILESYSTEM_ALLOWED_DIRS=
# Extra protected paths appended to defaults (kernel/, policy, taint.py, secret .env files, .git/, …)
# Changes take effect after backend restart.
# FILESYSTEM_PROTECTED_PATHS=

# Server (default localhost-only; Docker Compose overrides HOST to 0.0.0.0)
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Auth (optional — leave blank to disable API auth)
AUTH_TOKEN=
# Frontend Bearer token (must match AUTH_TOKEN when auth is enabled)
VITE_AUTH_TOKEN=

# MCP Configuration (leave blank to use repo-root defaults)
# MCP_CONFIG_PATH=
# CAPABILITY_POLICY_PATH=
MCP_EXTERNAL_ENABLED=true

# Builtin tools: comma-separated tool names to register, or * for all builtin
# tools (default). When blank, the lean core set is enabled.
BUILTIN_TOOLS_ENABLED=*

# Builtin tool CATEGORIES to register for the LLM. Leave blank for the lean
# core set (time, filesystem, web, calendar, email, browser, shell, git,
# telegram, goals). Add advanced categories to enable host-dependent tools:
#   BUILTIN_TOOL_CATEGORIES=computer_use,voice,clipboard_ocr
# (Add the core names too if you set this — only listed categories register.)
# BUILTIN_TOOL_CATEGORIES=

# External MCP credentials (servers auto-skip when required keys are missing)
BRAVE_API_KEY=
CONTEXT7_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
TAVILY_API_KEY=
NOTION_TOKEN=

# Email — Gmail (IMAP read inbox / SMTP send)
# Setup: enable 2FA → create App Password at https://myaccount.google.com/apppasswords
# EMAIL_PASS must be the 16-char app password, NOT your Google login password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
