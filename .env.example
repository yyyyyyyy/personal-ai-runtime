# LLM Configuration (required)
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional LLM Providers (used for fallback when primary fails)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Memory extraction: ollama (local) or cloud (uses LLM_API_KEY when Ollama unavailable)
MEMORY_EXTRACTOR=ollama

# Sensitive operations routing via local Ollama
SENSITIVE_OPS_LOCAL=false

# Data Storage
DATA_DIR=./backend/data
SQLITE_PATH=./backend/data/personal_ai.db
VECTOR_DIR=./backend/data/vectors

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MCP Configuration
MCP_CONFIG_PATH=./backend/mcp_config.json
CAPABILITY_POLICY_PATH=./backend/capability_policy.json

# Email (IMAP/SMTP)
EMAIL_USER=
EMAIL_PASS=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
