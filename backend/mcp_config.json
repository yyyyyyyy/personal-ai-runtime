{
  "servers": [
    {
      "name": "filesystem",
      "type": "builtin",
      "enabled": true,
      "config": {
        "allowed_directories": ["~/Documents", "~/Desktop", "~/Downloads"]
      }
    },
    {
      "name": "time",
      "type": "builtin",
      "enabled": true
    }
  ],
  "external_servers": [
    {
      "name": "example_external",
      "type": "stdio",
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"],
      "tools": [
        {
          "name": "external_echo",
          "description": "Echo arguments via external MCP server (example stub).",
          "parameters": {
            "type": "object",
            "properties": {
              "message": {"type": "string", "description": "Message to echo"}
            },
            "required": ["message"]
          },
          "mock_response": "echo ok",
          "requires_confirmation": false
        }
      ]
    }
  ]
}
